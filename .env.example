# ─────────────────────────────────────────────────────────────
# NextFlow — environment variables
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# REQUIRED FOR SUBMISSION: your full LinkedIn profile URL.
# Logged once on the initial client render of every page as:
#   [NextFlow] Candidate LinkedIn: <url>
NEXT_PUBLIC_CANDIDATE_LINKEDIN_URL="https://www.linkedin.com/in/REPLACE_ME"

# ── Clerk (https://clerk.com) ────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_c2V0dGxpbmctdHVydGxlLTY4LmNsZXJrLmFjY291bnRzLmRldiQ
CLERK_SECRET_KEY=sk_test_deToycSvP5N5F5iCYynbZJetEVgsEvqV2BDNETnioe
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# ── PostgreSQL / Neon (https://neon.tech) ────────────────────
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ── Google Gemini (https://aistudio.google.com/apikey) ───────
GOOGLE_GENERATIVE_AI_API_KEY="xxx"
# Default model id used by the Gemini node
GEMINI_DEFAULT_MODEL="gemini-3.1-pro"

# ── Trigger.dev (https://trigger.dev) ────────────────────────
TRIGGER_PROJECT_REF="proj_xxx"
TRIGGER_SECRET_KEY="tr_dev_xxx"
# Public access token so the browser can subscribe to run status (Realtime)
NEXT_PUBLIC_TRIGGER_API_URL="https://api.trigger.dev"

# ── Transloadit (https://transloadit.com) ────────────────────
NEXT_PUBLIC_TRANSLOADIT_KEY="xxx"
TRANSLOADIT_SECRET="xxx"
# Optional: a saved template id for image uploads (else we send inline steps)
TRANSLOADIT_TEMPLATE_ID=""
